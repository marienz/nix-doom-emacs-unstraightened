(defcli! build-profile-loader
    ((profile-name ("-n" form) "Profile name.")
     (base-directory ("-b" dir) "Base directory (for profile and straight).")
     (modules-dir ("-m" dir) "Doom modules directory.")
     (unset-profile ("-u") "Unset DOOMPROFILE at startup."))
  "Write Doom's profile loader."
  ;; See `dump'.
  (setf (caddr doom-module-load-path) (file-name-concat modules-dir "modules"))
  (let* ((profile-directory (expand-file-name "profile/" base-directory))
         (loaddefs-file (expand-file-name "doom-cli-loaddefs.el" base-directory))
         (load-file (expand-file-name "loader/init.el" base-directory))
         (new-profiles `((,profile-name
                          (_ :eval
;; HACK: install advice of doom-profile-dir from the profile loader,
;; because we do not gain control between here and Doom using this to find the
;; profile init file (from which our own init.el is loaded).
;;
;; Overriding doom-profile-dir affects doom-profile-init-dir and
;; doom-profile-init-file.

(defconst unstraightened--profile-dir ,profile-directory)

;; Having to specify this seems like a bug(?)
(declare-function doom-profile-init-dir@unstraightened "init")
(declare-function doom--dir "doom-lib")
(declare-function doom--profile "doom-lib")
(define-advice doom-profile-init-dir
    (:override (profile &rest segments) unstraightened)
  "Return unstraightened's profile directory (in the Nix store)."
  (declare (side-effect-free t))
  (let ((p (doom--profile profile)))
    (doom--dir (file-name-concat unstraightened--profile-dir (car p) (cdr p))
               segments)))

;; HACK: reset doom-profile-dir after Doom sets it.
;;
;; We cannot set it straight away because it is a defconst, which always
;; (re)sets the value. In newer versions of Doom `doom-initialize' then further
;; resets it: set it right after that.
(defvar doom-profile-dir)
(define-advice doom-initialize
    (:after (profile-id &optional interactive?) unstraightened)
  "Reset `doom-profile-dir' after `doom-initialize'."
  (setq doom-profile-dir (doom-profile-init-dir doom-profile)))
)
                          (user-emacs-directory . ,doom-emacs-dir)
                          (doom-module-load-path . ,doom-module-load-path)
                          (doom-cli-loaddefs-file . ,loaddefs-file)
                          ,@(when unset-profile '(("DOOMPROFILE" . nil)))))))
    (doom-profiles-write-load-file new-profiles load-file)
    ;; HACK: Disable native compilation to avoid a recompilation loop.
    ;;
    ;; When early-init.el loads this Emacs looks for the .eln file in its native
    ;; location, triggering async native compilation if it is missing there, but
    ;; async native compilation then writes it to its eln cache in
    ;; doom-profile-cache-dir, where it is never found.
    ;;
    ;; We trigger native-comp by having a function in the profile loader: that's
    ;; sufficiently unusual I won't try to get this changed in Doom proper
    ;; before 3.0.
    (find-file load-file)
    (add-file-local-variable-prop-line 'no-native-compile t)
    (save-buffer)
    (byte-compile-file load-file)))

(run! "build-profile-loader" (cdr (member "--" argv)))
