;; Set from run!
(defvar site-lisp)
(defvar init-file)

(defun generate-unstraightened-init-load (_profile)
  "Load unstraightened init.el."
  (make-symbolic-link init-file "00-unstraightened-init.load.el"))

(add-to-list 'doom-profile-generate-functions
             #'generate-unstraightened-init-load)

(defun generate-nix-autoloads (_profile)
  "Pull in autoloads for non-ELPA emacsWithPackages dependencies."
  ;; 65 is before -unstraightened-loaddefs (below)
  (doom-file-write
   "65-unstraightened-loaddefs-nix.init.el"
   `((defun unstraightened--startup-nix-loaddefs (_profile)
       ,@(let (filenames)
           (dolist (filename (directory-files site-lisp))
             (when (string-suffix-p "-autoloads.el" filename)
               (push (expand-file-name filename site-lisp) filenames)))
           (doom-loaddefs-scan-literal filenames)))
     (add-hook 'doom-startup-functions
               #'unstraightened--startup-nix-loaddefs 65))))

(add-to-list 'doom-profile-generate-functions #'generate-nix-autoloads)

;; Doom runs this with package.el initialized (but not activated, fixed below).
;; Store the side effects of activation in the profile to avoid (slow) package
;; activation during normal startup.
;;
;; package-activate-1 does:
;; - Load autoloads. Duplicated by generate-unstraightened-loaddefs.
;; - Add to load-path. Doom already stores load-path.
;; - Add Info node. Doom already stores Info-directory-list.
;; - Add name to package-activated-list. Stored below.

(defun generate-unstraightened-loaddefs (_profile)
  "Like doom-profile--generate-loaddefs-packages but for package.el."
  ;; 70 is the same priority as doom--startup-loaddefs-packages
  ;; (and before doom--startup-modules)
  (doom-file-write
   "70-unstraightened-loaddefs.init.el"
   `((defun unstraightened--startup-unstraightened-loaddefs (_profile)
       ,@(doom-loaddefs-scan-literal
          (mapcar (lambda (s)
                    (format "%s.el"
                            (package--autoloads-file-name
                             (package-get-descriptor s))))
                  ;; Packages are (currently...) pushed onto
                  ;; package-activated-list as they are activated. Reverse the
                  ;; list here so packages activated first get their autoloads
                  ;; loaded first.
                  ;;
                  ;; An example package that requires this is geiser-guile: it
                  ;; calls geiser-activate-implementation from autoloads,
                  ;; requiring geiser's autoloads are loaded first.
                  (reverse package-activated-list)))
       (set-default-toplevel-value 'package-activated-list
                                   ',package-activated-list))
     (add-hook 'doom-startup-functions
               #'unstraightened--startup-unstraightened-loaddefs 70))))

(add-to-list 'doom-profile-generate-functions #'generate-unstraightened-loaddefs)

(defcli! build-profile
    ((site-lisp ("-l" dir) "site-lisp directory to load autoloads from")
     (init-file ("-i" file) "unstraightened init.el"))
  "Write a Doom profile."
  ;; Doom initializes but does not activate package.el.
  ;; (This is idempotent, so no harm either way.)
  (package-activate-all)
  ;; This also loads our generated profile's init.el (so we include the right
  ;; packages in the profile).
  (doom-modules-initialize)
  ;; Load our init.el, so we can load straight without hitting
  ;; doom-initialize-packages / doom-initialize-core-packages.
  (doom-load init-file)
  ;; Now load straight (straight-prune-build-cache is not autoloaded).
  (require 'straight)
  ;; Trigger a write of straight's build cache (which we write into the profile
  ;; and load again later).
  (straight-prune-build-cache)
  (doom-profile-generate))

(run! "build-profile" (cdr (member "--" argv)))
