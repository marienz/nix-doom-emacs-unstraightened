(require 'json)

(defcli! dump
    ((modules-dir ("-m" dir) "Doom modules directory.")
     (output-directory ("-o" dir) "Directory to dump into."))
  "Dump intermediates for nix-doom-emacs-unstraightened."
  ;; Fail if doom-user-dir does not exist.
  ;;
  ;; It looks like this can happen if the user set doomDir to a non-store path,
  ;; which is not visible inside the Nix build sandbox. Doom does not seem to
  ;; error out on this: we end up with the same result as an empty doomDir.
  (unless (file-readable-p doom-user-dir)
    (user-error "DOOMDIR not readable: %s" doom-user-dir))
  (unless (string-equal (file-name-concat doom-emacs-dir "sources/doom+/modules")
                        (caddr doom-module-load-path))
    ;; If you hit this, you'll also need to update build-profile-loader.
    (user-error "nix-doom-emacs-unstraightened is not compatible with this version of Doom"))
  (setf (caddr doom-module-load-path) (file-name-concat modules-dir "modules"))

  ;; This also loads the user's init.el.
  (doom-modules-initialize)
  (let* ((all-packages (doom-package-list))
         (packages
          (cl-loop
           for (pname . plist) in all-packages
           ;; For recipes with :files, print it to a string before json-encode.
           ;; Otherwise it is serialized as a plist if it starts with :defaults.
           ;; We either ignore this or pass it to melpa2nix in a recipe.
           for files = (thread-first plist
                                     (plist-get :recipe) (plist-get :files))
           when files
           do (setf (thread-first plist (plist-get :recipe) (plist-get :files))
                    (prin1-to-string files))
           ;; For built-in packages, the :ignore property is the location of the
           ;; built-in library, which is a Nix store path. We do not want that
           ;; path to escape: avoid it by just filtering ignored packages here.
           unless (or (plist-get plist :ignore)
                      (plist-get plist :disable))
           collect (cons pname plist)))
         (default-directory output-directory))
    (doom-file-write "packages.json" (json-encode packages))
    (doom-file-write "doom-version" doom-version)
    (doom-file-write
     "packages.el"
     `(";;; packages.el -*- lexical-binding: t; -*-\n"
       "\n"
       ";; Package list generated by nix-doom-emacs-unstraightened.\n"
       "\n"
       ";; Disabled packages:\n"
       ,@(cl-loop for (pname . plist) in all-packages
                  when (plist-get plist :disable)
                  append `((package! ,pname :disable t) "\n"))
       "\n;; Packages installed by nix-doom-emacs-unstraightened or ignored by you:\n"
       ,@(cl-loop for (pname . plist) in all-packages
                  unless (plist-get plist :disable)
                  append `((package! ,pname :ignore t) "\n"))))))

(run! "dump" (cdr (member "--" argv)))
